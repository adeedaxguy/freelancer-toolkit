# Copy this file to .env.local and fill in your values
# Run: cp .env.local.example .env.local

# Admin dashboard password (change this!)
ADMIN_PASSWORD=change-me-to-something-secure

# ConvertKit API credentials
# Find these at: https://app.convertkit.com/account_settings/advanced_settings
CONVERTKIT_API_KEY=your_api_key_here
CONVERTKIT_API_SECRET=your_api_secret_here
